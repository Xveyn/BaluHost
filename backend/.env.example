# Backend environment example
# Copy this to backend/.env and adjust values for your deployment.

# General
DATABASE_URL=sqlite:///./baluhost.db
NAS_MODE=dev

# RAID settings
# Force use of the development (simulated) RAID backend even on Linux (useful for CI).
RAID_FORCE_DEV_BACKEND=0

# When true, mdadm array creation will include --assume-clean (DANGEROUS: do not enable in production)
RAID_ASSUME_CLEAN_BY_DEFAULT=0

# RAID scrub scheduler
# Enable periodic RAID scrubbing (set to 1 to enable; in CI/self-hosted runners prefer disabling)
RAID_SCRUB_ENABLED=0
# Interval in hours between automatic scrubs when enabled (default: 168 = 1 week)
RAID_SCRUB_INTERVAL_HOURS=168

# VCL storage path (empty = default HDD path at nas_storage_path/.system/versions)
# Set to SSD path for better performance, e.g. /mnt/cache-vcl/vcl
VCL_STORAGE_PATH=

# VPN encryption (generate a Fernet key for production)
VPN_ENCRYPTION_KEY=

# VPN endpoint settings
# DDNS hostname used as Endpoint in client configs (required for remote access)
VPN_PUBLIC_ENDPOINT=
# External port for NAS WireGuard (if port-forwarded; 0 = use internal port 51820)
VPN_PUBLIC_PORT=0
# Override server public key (use when wg0 interface cannot be read, e.g. dev mode)
# In production, the key is auto-read from the running wg0 interface
VPN_SERVER_PUBLIC_KEY=
