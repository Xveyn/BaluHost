# CODEOWNERS — required reviewers for security-sensitive paths.
#
# Reference: `.claude/rules/ci-cd-security.md` (Layer 1).
#
# Format: <path> <@owner...>
# Last matching pattern wins. Patterns follow gitignore globbing.
#
# Note: CODEOWNERS only blocks merges when the target branch has
# "Require review from Code Owners" enabled. On `main`, branch protection
# does NOT require approvals (solo-dev workflow: Xveyn merges manually).
# CODEOWNERS here still surfaces these paths as owner-flagged in the GitHub
# UI and documents the trust boundary; the hard gate is the `production`
# environment reviewer.

# CI/CD workflow definitions
/.github/workflows/  @Xveyn
/.github/CODEOWNERS  @Xveyn
/.github/workflows/tauri-build.yml @Xveyn
/.github/workflows/tui-build.yml @Xveyn

# Standalone TUI packaging (PyInstaller entry + .deb build)
/backend/packaging/tui/ @Xveyn

# Deploy scripts, systemd units, sudoers templates, runner bootstrap
/deploy/             @Xveyn
/scripts/bootstrap-runner-ubuntu.sh  @Xveyn
/scripts/bootstrap-ci-runner.sh      @Xveyn
/ci-config.example.conf              @Xveyn
/scripts/configure-ci.sh             @Xveyn

# Tauri Companion app (Rust shell + config)
/client/src-tauri/   @Xveyn

# Security & CI/CD rules — changes here weaken or strengthen the trust model
